{
    "name": "pangupay-extension",
    "version": "1.0.0",
    "description": "PanguPay - 盘古系统 UTXO 钱包浏览器扩展",
    "type": "module",
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "preview": "vite preview",
        "check:api": "node scripts/check-api-compat.js",
        "check:dapp": "node --experimental-strip-types scripts/check-dapp-tx-request.mjs",
        "check:protocol": "node scripts/check-protocol.js",
        "check:settlement-fixture": "node scripts/check-settlement-fixture.js",
        "check:browser-smoke": "node scripts/check-extension-browser-smoke.js",
        "check:dapp-browser-smoke": "node scripts/check-dapp-browser-smoke.js",
        "check:dapp-tx-browser-smoke": "node scripts/check-dapp-tx-browser-smoke.js",
        "check:dapp-tx-approve-browser-smoke": "node scripts/check-dapp-tx-approve-browser-smoke.js",
        "check:dapp-tx-approve-local-api-smoke": "node scripts/check-dapp-tx-approve-local-api-smoke.js",
        "check:real-backend-protocol": "node scripts/check-real-backend-protocol.js",
        "check:dapp-tx-real-backend-e2e": "node scripts/check-dapp-tx-real-backend-e2e.js"
    },
    "dependencies": {
        "crypto-js": "^4.2.0",
        "elliptic": "^6.5.4",
        "js-sha256": "^0.11.0",
        "json-bigint": "^1.0.0",
        "qrcode": "^1.5.3"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.0.0-beta.23",
        "@types/chrome": "^0.0.260",
        "@types/crypto-js": "^4.2.2",
        "@types/elliptic": "^6.4.18",
        "@types/qrcode": "^1.5.5",
        "typescript": "^5.3.3",
        "vite": "^5.0.12"
    }
}
